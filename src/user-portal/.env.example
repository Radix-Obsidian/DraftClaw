# DraftClaw User Portal - Environment Configuration
# Copy this file to .env and fill in your values

# ============ Server Configuration ============
DRAFTCLAW_PORTAL_PORT=3001
DRAFTCLAW_PORTAL_URL=http://localhost:3001
DRAFTCLAW_PORTAL_ORIGIN=http://localhost:3000
NODE_ENV=development

# ============ JWT Authentication ============
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
DRAFTCLAW_JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRY=900
JWT_REFRESH_TOKEN_EXPIRY=604800

# ============ Database Configuration ============
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/draftclaw_portal
# Redis for session caching (optional but recommended)
REDIS_URL=redis://localhost:6379

# ============ Stripe Configuration ============
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Stripe Price IDs - Create these in your Stripe Dashboard
# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_id
STRIPE_PRICE_PRO_YEARLY=price_pro_yearly_id
STRIPE_PRICE_GOAT_MONTHLY=price_goat_monthly_id
STRIPE_PRICE_GOAT_YEARLY=price_goat_yearly_id

# ============ WhatsApp Configuration ============
# Already configured in main .env - these are for portal integration
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token

# ============ Email Configuration (for notifications) ============
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@draftclaw.ai

# ============ Security ============
# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://draftclaw.ai

# ============ Sports Data APIs ============
# The Odds API - Get your key at https://the-odds-api.com/
ODDS_API_KEY=your_odds_api_key
ODDS_API_HOST=https://api.the-odds-api.com/v4

# Sportradar API
SPORTRADAR_BASKETBALL_API_KEY=your_sportradar_key
SPORTRADAR_BASKETBALL_HOST=https://api.sportradar.com/basketball

# SportsData.io API - Get your key at https://sportsdata.io/
SPORTSDATA_API_KEY=your_sportsdata_key
SPORTSDATA_API_HOST=https://api.sportsdata.io/v3

# ============ Background Services ============
# Odds sync interval (milliseconds) - Default: 300000 (5 minutes)
ODDS_UPDATE_INTERVAL=300000

# News feed sync interval (milliseconds) - Default: 900000 (15 minutes)
NEWS_UPDATE_INTERVAL=900000

# AI pick generation interval (milliseconds) - Default: 1800000 (30 minutes)
PICK_GENERATION_INTERVAL=1800000

# Fallback strategy for odds providers: 'sequential' or 'fastest'
ODDS_FALLBACK_STRATEGY=sequential

# ============ Monitoring ============
# Sentry DSN for error tracking (optional)
SENTRY_DSN=
# Log level: debug, info, warn, error
LOG_LEVEL=info
# Enable debug mode for services
DEBUG=false
