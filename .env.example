# Copy to .env and fill with your credentials

# ============ Twilio (Legacy WhatsApp) ============
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Must be a WhatsApp-enabled Twilio number, prefixed with whatsapp:
TWILIO_WHATSAPP_FROM=whatsapp:+17343367101

# ============ User Portal Configuration ============
DRAFTCLAW_PORTAL_PORT=3001
DRAFTCLAW_PORTAL_URL=http://localhost:3001
DRAFTCLAW_PORTAL_ORIGIN=http://localhost:3000

# JWT Authentication - Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
DRAFTCLAW_JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ============ Stripe Subscription Billing ============
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_id
STRIPE_PRICE_PRO_YEARLY=price_pro_yearly_id
STRIPE_PRICE_GOAT_MONTHLY=price_goat_monthly_id
STRIPE_PRICE_GOAT_YEARLY=price_goat_yearly_id

# ============ Database (for User Portal) ============
DATABASE_URL=postgresql://postgres:password@localhost:5432/draftclaw_portal
REDIS_URL=redis://localhost:6379

# ============ Supabase ============
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============ Sportradar APIs ============
SPORTRADAR_BASKETBALL_API_KEY=your_sportradar_basketball_key
SPORTRADAR_SOCCER_API_KEY=your_sportradar_soccer_key
SPORTRADAR_MMA_API_KEY=your_sportradar_mma_key

# ============ Sports Data APIs ============
ODDS_API_KEY=your_the_odds_api_key
SPORTSDATA_API_KEY=your_sportsdata_api_key

# ============ Python Orchestrator ============
ORCHESTRATOR_URL=http://localhost:8100
ORCHESTRATOR_API_KEY=your_orchestrator_secret_key
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key
